# Copiá este archivo a ".env" para probar local con "netlify dev".
# En producción estas variables se cargan en Netlify (Site settings > Environment variables).

# Datos de vuelos (RapidAPI - AeroDataBox). Obligatoria.
RAPIDAPI_KEY=pega-tu-key-aca

# Alertas por Telegram. Token que te da @BotFather al crear el bot.
TELEGRAM_BOT_TOKEN=pega-el-token-del-bot

# (Opcional) Alertas por email vía Resend. Solo si lo querés además de Telegram.
# RESEND_API_KEY=re_...
# MAIL_FROM=Te sigo de Viaje <onboarding@resend.dev>
